# PostgreSQL connection string
# Free options: Neon (neon.tech), Supabase, Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# ---- Local dev only ----
# Port for the API server (standalone mode, not used by Vercel)
PORT=8080
