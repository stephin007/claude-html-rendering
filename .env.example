# PostgreSQL connection string
# Free options: Neon (neon.tech), Supabase, Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# ---- OpenPanel analytics ----
# Create a project at https://openpanel.dev to get these values.
# VITE_ prefix exposes the value to the browser bundle — safe for a public client ID.
VITE_OPENPANEL_CLIENT_ID=your-openpanel-client-id
# These two are backend-only. Never use VITE_ prefix for the secret.
OPENPANEL_CLIENT_ID=your-openpanel-client-id
OPENPANEL_CLIENT_SECRET=your-openpanel-client-secret

# ---- Local dev only ----
# Port for the API server
PORT=8080
# Port the frontend Vite proxy forwards /api/* calls to (must match PORT above)
API_PORT=8080
