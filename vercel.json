{
  "buildCommand": "pnpm --filter @workspace/framelink run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/framelink/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
